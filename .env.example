# Required for any live scraper execution (use one transport path)
SBR_CDP_URL=wss://example.invalid
# BRIGHTDATA_BROWSER_WS=wss://...
# BRIGHTDATA_PROXY_SERVER=brd.superproxy.io:33335
# BRIGHTDATA_PROXY_USERNAME=your-brightdata-username
# BRIGHTDATA_PROXY_PASSWORD=your-brightdata-password

# Required for Google Sheets publishing
SHEETS_KEY={"type":"service_account","project_id":"..."}
SHEET_ID=your-google-sheet-id

# Required to trigger authenticated scheduled runs
SCHEDULE_RUN_TOKEN=replace-with-long-random-token

# Optional runtime configuration
PORT=8080
DATABASE_URL=postgresql://user:password@host:5432/dbname
MERGED_SHEET_ID=destination-google-sheet-id
GIT_SHA=local-dev

# Optional alerts
LEAD_ALERT_WEBHOOK_URL=
LEAD_ALERT_RESEND_API_KEY=
LEAD_ALERT_EMAIL_FROM=
LEAD_ALERT_EMAIL_TO=antigravity1@timberlinetax.com

# Optional scheduler/site tuning
NYC_ACRIS_TRANSPORT_MODE=legacy-sbr-cdp
SCHEDULE_NYC_ACRIS_MAX_RECORDS=75
SCHEDULE_SLA_ENFORCEMENT_MODE=observe
SCHEDULE_AUTO_THROTTLE=1
SCHEDULE_MAX_RECORDS_FLOOR=25
SCHEDULE_MAX_RECORDS_CEILING=1000
AMOUNT_MIN_COVERAGE_PCT=95
REQUIRE_OCR_TOOLS=1

# Optional scraper tuning
ACRIS_INITIAL_MAX_RECORDS=5
ACRIS_INITIAL_MAX_RESULT_PAGES=1
MARICOPA_MAX_RECORDS=1000
MARICOPA_ENABLE_ARTIFACT_RETRIEVAL=1
MARICOPA_SESSION_MAX_AGE_MINUTES=720
MARICOPA_ARTIFACT_CANDIDATE_MAX_AGE_MINUTES=1440
