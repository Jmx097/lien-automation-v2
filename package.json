  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "ts-node src/server.ts",
    "test": "npm run test:types && npm run test:selector-smoke",
    "worker": "ts-node src/worker/index.ts",
    "test:types": "tsc --noEmit",
    "test:smoke": "node scripts/smoke-health.js",
    "doctor": "node scripts/doctor.js",
    "test:selector-smoke": "vitest --config vitest.config.mts run tests/selector-smoke.test.ts",
    "test:workflow-syntax": "prettier --check \".github/workflows/*.yml\"",
    "test:cloud-shell": "node scripts/check-cloud-shell-syntax.js",
    "test:cloud": "vitest --config vitest.config.mts run tests/scripts/resolve-secret-ref.test.ts",
    "test:gates": "vitest --config vitest.config.mts run tests/gates/",
    "test:retry": "vitest --config vitest.config.mts run tests/utils/retry-policy.test.ts",
    "test:amount": "vitest --config vitest.config.mts run tests/utils/amount-extraction.test.ts",
    "test:scheduler": "vitest --config vitest.config.mts run tests/scheduler/",
    "demo:chunk": "ts-node scripts/run-chunk-demo.ts",
    "calibrate:cap": "ts-node scripts/calibrate-schedule-cap.ts",
    "test:ca-sos-range": "ts-node scripts/run-ca-sos-range.ts",
    "canary:ca-sos": "ts-node scripts/run-ca-sos-canary.ts",
    "validate:nyc-acris-live": "ts-node scripts/validate-nyc-acris-live.ts",
    "probe:nyc-bootstrap": "ts-node scripts/probe-nyc-bootstrap.ts",
    "canary:nyc-acris": "ts-node scripts/run-nyc-acris-canary.ts",
    "validate:maricopa-live": "ts-node scripts/validate-maricopa-live.ts",
    "canary:maricopa": "ts-node scripts/run-maricopa-canary.ts",
    "proof:all-sites-live": "ts-node scripts/run-live-proof.ts",
    "proof:scheduled-evidence": "ts-node scripts/run-scheduled-evidence-proof.ts",
    "discover:maricopa-live": "ts-node scripts/discover-maricopa-live.ts",
    "refresh:maricopa-session": "ts-node scripts/refresh-maricopa-session.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "start:job": "node dist/src/job-entrypoint.js",
    "dev:job": "ts-node src/job-entrypoint.ts"
  },
  "keywords": [],
